Class 1: RecyclableItem.java
public class RecyclableItem {
private String itemId;
private String name;
private int recycleCount;
private String category;
// No-argument constructor
public RecyclableItem() {
}
// Four-argument constructor
public RecyclableItem(String itemId, String name, int recycleCount, String category) {
this.itemId = itemId;
this.name = name;
this.recycleCount = recycleCount;
this.category = category;
}
// Getters and Setters
public String getItemId() {
return itemId;
}
public void setItemId(String itemId) {
this.itemId = itemId;
}
public String getName() {
return name;
}
public void setName(String name) {
this.name = name;
}
public int getRecycleCount() {
return recycleCount;
}
public void setRecycleCount(int recycleCount) {
this.recycleCount = recycleCount;
}
public String getCategory() {
return category;
}
public void setCategory(String category) {
this.category = category;
}
}
✅ Class 2: RecyclingUtil.java
import java.util.*;
public class RecyclingUtil {
private List<RecyclableItem> itemList = new ArrayList<>();
public List<RecyclableItem> getItemList() {
return itemList;
}
public void setItemList(List<RecyclableItem> itemList) {
this.itemList = itemList;
}
// Requirement 1
public void addRecyclingRecord(RecyclableItem item) {
itemList.add(item);
}
// Requirement 2
public RecyclableItem getItemById(String itemId) {
for (RecyclableItem item : itemList) {
if (item.getItemId().equals(itemId)) {
return item;
}
}
return null;
}
// Requirement 3
public Set<RecyclableItem> getMostRecycledItems() {
Set<RecyclableItem> result = new LinkedHashSet<>();
int maxRecycleCount = 0;
for (RecyclableItem item : itemList) {
if (item.getRecycleCount() > maxRecycleCount) {
maxRecycleCount = item.getRecycleCount();
}
}
for (RecyclableItem item : itemList) {
if (item.getRecycleCount() == maxRecycleCount) {
result.add(item);
}
}
return result;
}
}
✅ Class 3: UserInterface.java
import java.util.*;
public class UserInterface {
public static void main(String[] args) {
Scanner sc = new Scanner(System.in);
RecyclingUtil util = new RecyclingUtil();
System.out.println("Enter the number of recyclable items to be added");
int size = sc.nextInt();
sc.nextLine();
System.out.println("Enter item details");
for (int i = 0; i < size; i++) {
String input = sc.nextLine();
String[] parts = input.split(":");
String itemId = parts[0];
String name = parts[1];
int recycleCount = Integer.parseInt(parts[2]);
String category = parts[3];
RecyclableItem item =
new RecyclableItem(itemId, name, recycleCount, category);
util.addRecyclingRecord(item);
}
System.out.println("Enter the Item Id to check recycling status");
String searchId = sc.nextLine();
RecyclableItem foundItem = util.getItemById(searchId);
if (foundItem != null) {
System.out.println(foundItem.getItemId() + " | "
+ foundItem.getName() + " | "
+ foundItem.getCategory() + " | "
+ foundItem.getRecycleCount() + " times recycled");
} else {
System.out.println("Item Id not found");
}
System.out.println("Most recycled items are");
Set<RecyclableItem> mostRecycled = util.getMostRecycledItems();
for (RecyclableItem item : mostRecycled) {
System.out.println(item.getItemId() + " | "
+ item.getName() + " | "
+ item.getCategory() + " | "
+ item.getRecycleCount() + " times recycled");
}
sc.close();
}
}






















