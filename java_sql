
<div class="dashboard-container">

  <div class="sidebar">
    <h2>Trade Manager</h2>

    <ul>
      <li>Dashboard</li>
      <li>File Search</li>
      <li>Upload Files</li>
      <li>Archive</li>
      <li>Settings</li>
    </ul>

  </div>

  <div class="main-content">

    <div class="navbar">
      Trade File Processing Dashboard
    </div>

    <div class="cards">

      <div class="card">
        <h3>Files Loaded</h3>
        <p>24</p>
      </div>

      <div class="card">
        <h3>Processing</h3>
        <p>3</p>
      </div>

      <div class="card">
        <h3>Failed</h3>
        <p>2</p>
      </div>

      <div class="card">
        <h3>Archived</h3>
        <p>18</p>
      </div>

    </div>

    <div class="table-container">

      <h3>Recent File Loads</h3>

      <table>

        <thead>
          <tr>
            <th>ID</th>
            <th>Filename</th>
            <th>Date</th>
            <th>Status</th>
            <th>Records</th>
          </tr>
        </thead>

        <tbody>

          <tr *ngFor="let file of files">

            <td>{{file.id}}</td>
            <td>{{file.name}}</td>
            <td>{{file.date}}</td>

            <td
            [ngClass]="{
            'status-loaded':file.status==='Loaded',
            'status-processing':file.status==='Processing',
            'status-failed':file.status==='Failed',
            'status-archived':file.status==='Archived'
            }">
            {{file.status}}
            </td>

            <td>{{file.records}}</td>

          </tr>

        </tbody>

      </table>

    </div>

  </div>

</div>




background:#555879;
color:white;
padding:15px;
border-radius:6px;
margin-bottom:20px;
}

.cards{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
margin-bottom:20px;
}

.card{
background:#F4EBD3;
padding:20px;
border-radius:8px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

.card h3{
margin:0;
color:#555879;
}

.card p{
font-size:22px;
margin-top:10px;
}

.table-container{
background:white;
padding:20px;
border-radius:8px;
}

table{
width:100%;
border-collapse:collapse;
}

th{
background:#98A1BC;
color:white;
padding:10px;
}

td{
padding:10px;
border-bottom:1px solid #eee;
}

.status-loaded{
color:green;
font-weight:bold;
}

.status-processing{
color:orange;
font-weight:bold;
}

.status-failed{
color:red;
font-weight:bold;
}

.status-archived{
color:#555879;
font-weight:bold;
}


